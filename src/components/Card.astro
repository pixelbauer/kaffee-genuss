---
// Karte für Hersteller / Wissenswertes / Modelle (DESIGN.md §5).
// Mit `image` echtes Foto (astro:assets, lazy); sonst Monogramm/Gradient.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
interface Props {
  href: string;
  title: string;
  teaser?: string;
  eyebrow?: string;
  cta?: string;
  initials?: string;
  image?: ImageMetadata;
  imageAlt?: string;
}
const { href, title, teaser, eyebrow, cta = 'Mehr erfahren', initials, image, imageAlt = '' } = Astro.props;
---

<a href={href} class="card">
  <div class="card-img" aria-hidden={image ? undefined : 'true'}>
    {image && (
      <Image src={image} alt={imageAlt} class="card-photo" widths={[320, 480, 640]} sizes="(min-width: 900px) 360px, (min-width: 560px) 45vw, 92vw" loading="lazy" />
    )}
    {!image && initials && <span class="card-initials">{initials}</span>}
    {eyebrow && <span class="card-eyebrow">{eyebrow}</span>}
  </div>
  <div class="card-body">
    <h3>{title}</h3>
    {teaser && <p>{teaser}</p>}
    <span class="card-arrow">{cta} →</span>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--sahne);
    border: 1px solid var(--roest-100);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    height: 100%;
  }
  .card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--crema);
    transform: translateY(-2px);
  }
  .card-img {
    aspect-ratio: 4 / 3;
    background:
      radial-gradient(140px 100px at 72% 28%, rgba(224, 138, 43, 0.32), transparent 70%),
      linear-gradient(135deg, var(--bohne), var(--espresso));
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 14px;
    position: relative;
  }
  .card-initials {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 2rem;
    color: rgba(247, 243, 236, 0.92);
    letter-spacing: 0.02em;
  }
  .card-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Eyebrow auf Foto lesbar */
  .card-img:has(.card-photo) { background: var(--espresso); }
  .card-img:has(.card-photo)::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(59, 36, 23, 0) 45%, rgba(59, 36, 23, 0.55));
  }
  .card-eyebrow {
    position: relative;
    z-index: 1;
    color: var(--crema);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  }
  .card-body { padding: 16px 18px 18px; display: flex; flex-direction: column; flex: 1; }
  .card-body h3 { font-size: 1.15rem; }
  .card-body p { margin-top: 6px; font-size: 0.9rem; color: var(--roest-700); flex: 1; }
  .card-arrow { margin-top: 14px; color: var(--signal); font-weight: 600; font-size: 0.88rem; }
</style>
