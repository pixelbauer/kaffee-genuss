---
import { SITE } from '@/lib/site';
interface Crumb { label: string; href?: string }
interface Props { items: Crumb[] }
const { items } = Astro.props;

const full = [{ label: 'Start', href: '/' }, ...items];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: full.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(c.href ? { item: new URL(c.href, SITE.url).href } : {}),
  })),
};
---

<nav aria-label="Brotkrumen" class="crumbs">
  <ol>
    {
      full.map((c, i) => (
        <li>
          {c.href && i < full.length - 1 ? (
            <a href={c.href}>{c.label}</a>
          ) : (
            <span aria-current="page">{c.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

<style>
  .crumbs ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.85rem;
    color: var(--roest-300);
  }
  .crumbs li:not(:first-child)::before {
    content: '/';
    margin-right: 6px;
    color: var(--roest-300);
  }
  .crumbs a { color: var(--bohne); text-decoration: none; }
  .crumbs a:hover { text-decoration: underline; }
  .crumbs span[aria-current] { color: var(--roest-700); }
</style>
