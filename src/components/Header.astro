---
import { NAV_MAIN, SITE } from '@/lib/site';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class="site-header">
  <div class="container-page header-inner">
    <a href="/" class="brand" aria-label={`${SITE.name} – Startseite`}>
      <svg width="26" height="26" viewBox="0 0 32 32" aria-hidden="true">
        <rect width="32" height="32" rx="3" fill="#3B2417"></rect>
        <ellipse cx="16" cy="15" rx="5" ry="7" fill="#C8A26A"></ellipse>
        <path d="M16 8c0 4 0 10 0 14" stroke="#3B2417" stroke-width="1.4" fill="none"></path>
        <circle cx="23" cy="9" r="2.2" fill="#E08A2B"></circle>
      </svg>
      <span class="brand-name">Kaffee-Genuss<span class="brand-tld">.net</span></span>
    </a>

    <nav class="nav-desktop" aria-label="Hauptnavigation">
      {
        NAV_MAIN.map((item) => (
          <a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]} aria-current={isActive(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
      <a href="/beratung/" class="nav-cta">Angebote vergleichen</a>
    </nav>

    <details class="nav-mobile">
      <summary aria-label="Menü öffnen">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </summary>
      <div class="nav-mobile-panel">
        {
          NAV_MAIN.map((item) => (
            <a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          ))
        }
        <a href="/beratung/" class="nav-cta">Angebote vergleichen</a>
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--sahne) 92%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--roest-100);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 16px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--espresso);
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1.15rem;
  }
  .brand-tld { color: var(--crema); }

  .nav-desktop { display: none; align-items: center; gap: 4px; }
  .nav-link {
    text-decoration: none;
    color: var(--roest-700);
    font-size: 0.95rem;
    font-weight: 500;
    padding: 8px 12px;
    border-radius: 2px;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav-link:hover { color: var(--espresso); background: var(--milch); }
  .nav-link.active { color: var(--espresso); box-shadow: inset 0 -2px 0 var(--signal); }
  .nav-cta {
    margin-left: 8px;
    text-decoration: none;
    background: var(--signal);
    color: #fff;
    font-weight: 600;
    font-size: 0.92rem;
    padding: 10px 18px;
    border-radius: var(--radius-pill);
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .nav-cta:hover { background: var(--signal-700); transform: translateY(-1px); }

  /* Mobile */
  .nav-mobile { position: relative; }
  .nav-mobile summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--espresso);
    border: 1px solid var(--roest-100);
    border-radius: 2px;
    background: var(--sahne);
  }
  .nav-mobile summary::-webkit-details-marker { display: none; }
  .nav-mobile-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 10px);
    width: min(78vw, 280px);
    background: var(--sahne);
    border: 1px solid var(--roest-100);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .nav-mobile-panel .nav-link { padding: 12px; border-radius: 2px; }
  .nav-mobile-panel .nav-cta { margin: 8px 0 0; text-align: center; }

  @media (min-width: 900px) {
    .nav-desktop { display: flex; }
    .nav-mobile { display: none; }
  }
</style>
