---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
---

<BaseLayout title="Seite nicht gefunden" description="Die aufgerufene Seite existiert nicht." noindex>
  <div class="nf">
    <span class="nf-code">404</span>
    <h1>Diese Seite haben wir nicht gefunden</h1>
    <p>
      Vielleicht wurde die Adresse geändert oder der Link ist veraltet. Finden Sie hier
      weiter:
    </p>
    <div class="nf-actions">
      <Button href="/" variant="secondary">Zur Startseite</Button>
      <Button href="/beratung/" variant="primary">Angebote vergleichen</Button>
    </div>
    <ul class="nf-links">
      <li><a href="/hersteller/">Hersteller</a></li>
      <li><a href="/modelle/">Modelle</a></li>
      <li><a href="/wissenswertes/">Wissenswertes</a></li>
      <li><a href="/faq/">FAQ</a></li>
    </ul>
  </div>
</BaseLayout>

<style>
  .nf { max-width: 600px; margin: 24px auto; text-align: center; padding: 24px 0; }
  .nf-code { font-family: var(--font-head); font-weight: 600; font-size: 4rem; color: var(--crema); }
  .nf h1 { margin-top: 8px; font-size: clamp(1.6rem, 1.2rem + 2vw, 2.2rem); }
  .nf p { margin-top: 12px; color: var(--roest-700); }
  .nf-actions { margin-top: 24px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .nf-links { list-style: none; padding: 0; margin: 28px 0 0; display: flex; gap: 18px; justify-content: center; flex-wrap: wrap; }
  .nf-links a { color: var(--signal-700); text-decoration: none; font-weight: 500; }
  .nf-links a:hover { text-decoration: underline; }
</style>
