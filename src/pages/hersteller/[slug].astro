---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import CTABox from '@/components/CTABox.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import { brandSchema } from '@/lib/schema';
import { herstellerImage } from '@/lib/images';

export async function getStaticPaths() {
  const all = await getCollection('hersteller');
  return all.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const url = `/hersteller/${entry.id}/`;

// verwandte Hersteller auflösen
const all = await getCollection('hersteller');
const related = entry.data.related
  .map((id) => all.find((h) => h.id === id))
  .filter((x): x is NonNullable<typeof x> => Boolean(x));
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.lead}
  canonicalPath={url}
  schema={[brandSchema(entry.data.name, entry.data.lead, url)]}
>
  <Breadcrumbs items={[{ label: 'Hersteller', href: '/hersteller/' }, { label: entry.data.name }]} />

  <article class="detail">
    <header class="ahero">
      <Image src={herstellerImage(entry.data.segment)} alt="" class="ahero-bg" widths={[480, 760, 1000]} sizes="(min-width: 800px) 760px, 92vw" loading="eager" />
      <div class="ahero-inner">
        <span class="ahero-cat">{entry.data.segment}</span>
        <h1>{entry.data.title}</h1>
        <p class="ahero-lead">{entry.data.lead}</p>
      </div>
    </header>

    <div class="prose">
      <Content />
    </div>

    <div class="cta-wrap">
      <CTABox title={`${entry.data.name}-Angebote vergleichen`} />
    </div>

    {
      related.length > 0 && (
        <section class="related">
          <h2>Verwandte Hersteller</h2>
          <ul>
            {related.map((r) => (
              <li>
                <a href={`/hersteller/${r.id}/`}>
                  <strong>{r.data.name}</strong>
                  <span>{r.data.segment}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .detail { max-width: 820px; margin-inline: auto; }
  .detail .prose { max-width: 100%; }

  /* Article-Hero: Bild als Header-Hintergrund + Espresso-Overlay (wie Startseiten-Hero) */
  .ahero {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    min-height: clamp(260px, 38vw, 400px);
    display: flex;
    align-items: flex-end;
    box-shadow: var(--shadow-md);
  }
  .ahero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .ahero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(43, 24, 16, 0.15) 0%,
      rgba(43, 24, 16, 0.45) 45%,
      rgba(43, 24, 16, 0.86) 100%
    );
  }
  .ahero-inner {
    position: relative;
    z-index: 2;
    padding: 28px 28px 26px;
    color: var(--milch);
  }
  .ahero-cat {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--crema);
    font-weight: 600;
    margin-bottom: 10px;
  }
  .ahero-inner h1 {
    color: var(--milch);
    font-size: clamp(1.7rem, 1.1rem + 2.6vw, 2.5rem);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.35);
  }
  .ahero-lead {
    margin-top: 10px;
    font-size: 1.1rem;
    color: rgba(247, 243, 236, 0.9);
    max-width: 60ch;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.3);
  }
  .prose { margin-top: 32px; }
  .cta-wrap { margin-top: 40px; }

  .related { margin-top: 44px; border-top: 1px solid var(--roest-100); padding-top: 28px; }
  .related h2 { font-size: 1.3rem; }
  .related ul { list-style: none; padding: 0; margin: 16px 0 0; display: grid; gap: 10px; grid-template-columns: 1fr; }
  @media (min-width: 600px) { .related ul { grid-template-columns: repeat(3, 1fr); } }
  .related a {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    background: var(--sahne);
    border: 1px solid var(--roest-100);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .related a:hover { border-color: var(--crema); box-shadow: var(--shadow-sm); }
  .related strong { color: var(--espresso); font-family: var(--font-head); }
  .related span { color: var(--roest-300); font-size: 0.8rem; }
</style>
