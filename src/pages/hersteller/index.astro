---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import Card from '@/components/Card.astro';
import CTABox from '@/components/CTABox.astro';
import { getCollection } from 'astro:content';
import { HERSTELLER_ORDER } from '@/lib/site';

const all = await getCollection('hersteller');
const order = HERSTELLER_ORDER as readonly string[];
const sorted = all.sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));
const initials = (name: string) => name.replace(/[^A-Za-zÀ-ÿ]/g, '').slice(0, 2).toUpperCase();
---

<BaseLayout
  title="Hersteller von Kaffeevollautomaten im Überblick"
  description="Die wichtigsten Hersteller von Kaffeevollautomaten für Büro & Gastronomie: WMF, Jura, Melitta, Siemens, Saeco, Faema und mehr – mit Fokus auf den gewerblichen Einsatz."
>
  <Breadcrumbs items={[{ label: 'Hersteller' }]} />

  <SectionHeading as="h1" eyebrow="Marken im Vergleich">
    Hersteller von Kaffeevollautomaten
  </SectionHeading>
  <p class="intro">
    Welche Marke passt zu Ihrem Einsatz? Wir ordnen die wichtigsten Hersteller nach ihrem
    Nutzen für Büro, Gastronomie und Hotellerie ein – von Vollgewerbe bis Semi-Professional.
    Für ein konkretes Angebot nutzen Sie den <a href="/beratung/">Konfigurator</a>.
  </p>

  <div class="grid">
    {
      sorted.map((h) => (
        <Card
          href={`/hersteller/${h.id}/`}
          title={h.data.name}
          teaser={h.data.lead}
          eyebrow={h.data.segment}
          initials={initials(h.data.name)}
          cta="Zum Hersteller"
        />
      ))
    }
  </div>

  <div class="cta-wrap">
    <CTABox />
  </div>
</BaseLayout>

<style>
  .intro { margin-top: 4px; max-width: 68ch; color: var(--roest-700); font-size: 1.0625rem; }
  .intro a { color: var(--signal-700); }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-top: 28px;
  }
  @media (min-width: 560px) { .grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 900px) { .grid { grid-template-columns: repeat(3, 1fr); } }
  .cta-wrap { margin-top: 48px; }
</style>
